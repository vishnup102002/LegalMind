# Database Credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secure_password_123

QDRANT_HOST=localhost
QDRANT_PORT=6333

REDIS_HOST=localhost
REDIS_PORT=6379

# Model Inference Configuration
VLLM_API_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=unsloth/llama-3.1-8b-instruct-bnb-4bit

# Audio Processing Gateways
SHRUTAM_API_URL=http://localhost:8010/v1/transcribe
SOOKTAM_API_URL=http://localhost:8020/v1/synthesize

# System Verification
CITATION_FAITHFULNESS_THRESHOLD=0.72

# Optional Cloud LLM API configurations for fast dev/testing (bypasses local Ollama if set)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
